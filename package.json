{
  "name": "kyravo-discord-radio",
  "version": "1.0.0",
  "description": "Discord radio bot with multi-channel auto-join and local web dashboard.",
  "type": "module",
  "scripts": {
    "start": "node src/supervisor.js",
    "bot": "node src/index.js",
    "dev": "node --watch src/index.js",
    "invite": "node src/invite.js",
    "discord:install-settings": "node src/setup-discord-install.js",
    "autostart:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-autostart.ps1",
    "autostart:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-kyravo.ps1",
    "autostart:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-autostart.ps1"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.15",
    "prism-media": "^1.3.5",
    "spotify-web-api-node": "^5.0.2"
  }
}
